# API Keys
ADZUNA_APP_ID=your_app_id
ADZUNA_API_KEY=your_api_key

# Email Config (optional)
EMAIL_ENABLED=false
EMAIL_USER=your_email
EMAIL_PASS=your_password

# Fetcher Configuration
SEARCH_KEYWORDS=python developer
MAX_WORKERS=5
PAGINATION_PAGES=3
REQUEST_TIMEOUT=10
RETRY_ATTEMPTS=3

# System Configuration
JOB_FETCH_LIMIT=500
MAX_JOB_AGE_HOURS=6
